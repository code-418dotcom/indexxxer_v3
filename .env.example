# ============================================================
#  indexxxer_v3 — environment variables
#  Copy to .env and fill in values before running docker compose
# ============================================================

# ---- API Auth (single static token for M1) -----------------
# Generate a strong random value: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=change-me-before-first-use

# ---- PostgreSQL --------------------------------------------
POSTGRES_PASSWORD=indexxxer_dev
# Used by docker-compose to build the DATABASE_URL inside containers
# (service hostname is "db" inside the compose network)
DATABASE_URL=postgresql+asyncpg://indexxxer:indexxxer_dev@db:5432/indexxxer

# For running the backend outside Docker (e.g. local uv run):
# DATABASE_URL=postgresql+asyncpg://indexxxer:indexxxer_dev@localhost:5432/indexxxer

# ---- Redis -------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# For running outside Docker:
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Media paths -------------------------------------------
# Host path to mount read-only into backend + worker containers
MEDIA_ROOT=/mnt/e/media

# Where generated thumbnails are stored (host path → mounted at /data/thumbnails)
# Created automatically by docker-compose; must be writable
THUMBNAIL_ROOT=./data/thumbnails

# ---- App settings ------------------------------------------
DEBUG=false
# CORS origins (comma-separated, no trailing slash)
CORS_ORIGINS=http://localhost:3000
